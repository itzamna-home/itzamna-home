# ---------------------------------------------------------------------------
# Context gathering
# ---------------------------------------------------------------------------

def run_silent(cmd: list[str]) -> str:
    return subprocess.run(cmd, capture_output=True, text=True).stdout.strip()


def base_context() -> dict:
    return {
        "hostname": run_silent(["hostname"]),
        "os":       run_silent(["uname", "-sr"]),
        "cwd":      run_silent(["pwd"]),
        "user":     run_silent(["whoami"]),
    }


def network_context() -> dict:
    info = {}
    for line in run_silent(["ip", "route", "show", "default"]).splitlines():
        parts = line.split()
        if "dev" in parts:
            info["interface"] = parts[parts.index("dev") + 1]
        if "via" in parts:
            info["gateway"] = parts[parts.index("via") + 1]
    if "interface" in info:
        for line in run_silent(["ip", "-o", "-4", "addr", "show", info["interface"]]).splitlines():
            parts = line.split()
            if "inet" in parts:
                info["ip_cidr"] = parts[parts.index("inet") + 1]
    return info


def disk_context() -> dict:
    return {"disk_usage": run_silent(["df", "-h", "--output=source,size,used,avail,pcent,target",
                                       "-x", "tmpfs", "-x", "devtmpfs"])}


def process_context() -> dict:
    return {"top_processes": "\n".join(
        run_silent(["ps", "aux", "--sort=-%cpu", "--no-headers", "-w"]).splitlines()[:10])}


def file_context(cwd: str) -> dict:
    return {"directory_listing": run_silent(["ls", "-lah", cwd])}


FREEFORM_TRIGGERS = {
    "network": ["network", "scan", "nmap", "ip", "interface", "subnet", "ping",
                "port", "device", "wifi", "ethernet", "route", "gateway", "host"],
    "disk":    ["disk", "partition", "storage", "space", "mount", "filesystem", "df", "du", "drive"],
    "process": ["process", "cpu", "memory", "ram", "pid", "running", "kill", "top", "htop", "service"],
    "file":    ["file", "directory", "folder", "list", "count", "find", "ls", "tree", "path"],
}


def gather_context(tags: list[str], cwd: str = ".") -> str:
    ctx = base_context()
    if "network" in tags:
        ctx.update(network_context())
    if "disk" in tags:
        ctx.update(disk_context())
    if "process" in tags:
        ctx.update(process_context())
    if "file" in tags:
        ctx.update(file_context(cwd))
    return "System context:\n" + "\n".join(f"{k}: {v}" for k, v in ctx.items())


def freeform_context(prompt: str) -> str:
    triggered = [k for k, kws in FREEFORM_TRIGGERS.items() if any(w in prompt.lower() for w in kws)]
    dbg("context triggers", triggered)
    ctx = base_context()
    cwd = ctx["cwd"]
    return gather_context(triggered, cwd)

