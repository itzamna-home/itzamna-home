def dbg(label: str, value=None) -> None:
    if not DEBUG:
        return
    txt = f"{GRAY}[debug] {label}"
    if value is not None:
        txt += f": {value}"
    print(txt + RESET, flush=True)

# ---------------------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------------------

def ask_ollama(prompt: str, system: str, context: str = "") -> str:
    full_prompt = f"{context}\n\n{prompt}" if context else prompt
    payload = {"model": MODEL, "system": system, "prompt": full_prompt, "stream": True}

    dbg("POST", ollama_url())
    dbg("payload", json.dumps(payload, indent=2))

    t0 = time.time()
    try:
        response = requests.post(ollama_url(), json=payload, timeout=30, stream=True)
    except requests.exceptions.ConnectionError:
        print(f"{RED}[error]{RESET} Cannot connect to Ollama at {ollama_url()}")
        print("        Is Ollama running? Try: ollama serve")
        raise
    except requests.exceptions.Timeout:
        print(f"{RED}[error]{RESET} Ollama did not respond within 30s — check: ollama ps")
        raise

    dbg("status", response.status_code)
    response.raise_for_status()

    reply = ""
    print(f"{GRAY}", end="", flush=True)
    for raw_line in response.iter_lines():
        if not raw_line:
            continue
        try:
            chunk = json.loads(raw_line)
        except json.JSONDecodeError:
            continue
        token = chunk.get("response", "")
        reply += token
        print(token, end="", flush=True)
        if chunk.get("done"):
            elapsed = time.time() - t0
            print(RESET, flush=True)
            dbg(f"tokens in={chunk.get('prompt_eval_count')} out={chunk.get('eval_count')} elapsed={elapsed:.2f}s")
            break

    if not reply:
        print(f"{RESET}{YELLOW}[warn]{RESET} Ollama returned an empty response.")
    return reply


def list_models() -> None:
    try:
        r = requests.get(ollama_tags_url(), timeout=5)
        r.raise_for_status()
        models = [m["name"] for m in r.json().get("models", [])]
        print("Available models:")
        for m in models:
            print(f"  {m}")
    except requests.RequestException as e:
        print(f"Could not fetch models: {e}")

# ---------------------------------------------------------------------------
# Command execution
# ---------------------------------------------------------------------------

def extract_commands(text: str) -> list[str]:
    match = re.search(r"```(?:bash|sh)?\n(.*?)```", text, re.DOTALL)
    block = match.group(1) if match else text
    if not match:
        dbg("no code block found, using raw text")
    return [ln.strip() for ln in block.splitlines() if ln.strip() and not ln.startswith("#")]


def needs_sudo(stderr: str) -> bool:
    keywords = ["root privileges", "requires root", "permission denied", "operation not permitted"]
    return any(k in stderr.lower() for k in keywords)


def run_commands(commands: list[str], sudo: bool = False, logfile: Path | None = None) -> tuple[bool, str]:
    print()
    all_ok = True
    last_stderr = ""

    for cmd_str in commands:
        prefix = ["sudo"] if sudo else []
        flags  = ["-x", "-c"] if DEBUG else ["-c"]
        cmd    = prefix + ["bash"] + flags + [cmd_str]

        print(f"{CYAN}${RESET} {cmd_str}")
        if logfile:
            logfile.write_text(logfile.read_text() + f"$ {cmd_str}\n" if logfile.exists() else f"$ {cmd_str}\n")

        result = subprocess.run(cmd, text=True, stderr=subprocess.PIPE if not DEBUG else None,
                                stdout=subprocess.PIPE)
        stdout_out = result.stdout or ""
        stderr_out = result.stderr or ""

        if stdout_out:
            print(stdout_out, end="")
        if logfile and stdout_out:
            logfile.write_text(logfile.read_text() + stdout_out)

        if result.returncode != 0:
            if stderr_out:
                print(stderr_out, end="")
            print(f"{RED}[exit {result.returncode}]{RESET}")
            all_ok = False
            last_stderr = stderr_out
        else:
            print(f"{GREEN}[ok]{RESET}")

    return all_ok, last_stderr

# ---------------------------------------------------------------------------
# Audit wizard
# ---------------------------------------------------------------------------

def pick(options: list[str], title: str) -> str | None:
    print(f"\n{BOLD}{title}{RESET}")
    for i, opt in enumerate(options, 1):
        print(f"  {CYAN}{i}.{RESET} {opt}")
    try:
        raw = input(f"\n{BOLD}Select [1-{len(options)}] or Enter to cancel:{RESET} ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if not raw:
        return None
    try:
        idx = int(raw) - 1
        if 0 <= idx < len(options):
            return options[idx]
    except ValueError:
        pass
    print(f"{YELLOW}Invalid selection.{RESET}")
    return None


def run_audit() -> None:
    categories = list(AUDITS.keys())
    category = pick(categories, "Audit Category")
    if not category:
        return

    subcategories = list(AUDITS[category].keys())
    subcategory = pick(subcategories, f"{category} → Sub-category")
    if not subcategory:
        return

    audit_def = AUDITS[category][subcategory]

    try:
        target = input(f"\n{BOLD}Target{RESET} (IP, subnet, URL, path, domain): ").strip()
    except (EOFError, KeyboardInterrupt):
        return
    if not target:
        print(f"{YELLOW}No target specified.{RESET}")
        return

    print(f"\n{GRAY}Gathering context...{RESET}", flush=True)
    ctx = gather_context(audit_def["context"])
    ctx += f"\ntarget: {target}"
    dbg("audit context", ctx)

    prompt = f"Audit target: {target}\nAudit type: {category} / {subcategory}"
    system = BASE_SYSTEM_PROMPT + "\n\n" + audit_def["prompt"]

    print(f"{GRAY}Generating audit commands...{RESET}", flush=True)
    try:
        reply = ask_ollama(prompt, system=system, context=ctx)
    except requests.RequestException:
        return

    commands = extract_commands(reply)
    if not commands:
        print(f"{YELLOW}No commands found in response.{RESET}")
        return

    print(f"\n{BOLD}Audit plan — {category} / {subcategory} → {target}{RESET}")
    for i, cmd in enumerate(commands, 1):
        print(f"  {CYAN}{i}.{RESET} {cmd}")

    # Report file
    ts      = datetime.now().strftime("%Y-%m-%d_%H-%M")
    slug    = f"{category}-{subcategory}".replace(" ", "_").replace("/", "-")
    logpath = Path(f"audit_{ts}_{slug}.txt")
    logpath.write_text(
        f"# Audit: {category} / {subcategory}\n"
        f"# Target: {target}\n"
        f"# Date:   {ts}\n\n"
    )

    confirm = input(f"\n{BOLD}Run audit?{RESET} Output → {logpath}  [y/N] ").strip().lower()
    if confirm != "y":
        print("Skipped.")
        logpath.unlink(missing_ok=True)
        return

    success, stderr_out = run_commands(commands, logfile=logpath)
    if not success and needs_sudo(stderr_out):
        retry = input(f"\n{YELLOW}Needs root. Retry with sudo?{RESET} [y/N] ").strip().lower()
        if retry == "y":
            run_commands(commands, sudo=True, logfile=logpath)

    print(f"\n{GREEN}Audit complete.{RESET} Report saved to {logpath}")

