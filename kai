# Main
# ---------------------------------------------------------------------------

def main():
    global DEBUG, MODEL, OLLAMA_HOST

    parser = argparse.ArgumentParser(description="Local AI shell + security audit via Ollama")
    parser.add_argument("--debug",       action="store_true",    help="Show request/response details")
    parser.add_argument("--model",       default=MODEL,           help=f"Ollama model (default: {MODEL})")
    parser.add_argument("--host",        default=OLLAMA_HOST,     help=f"Ollama host (default: {OLLAMA_HOST})")
    parser.add_argument("--list-models", action="store_true",     help="List available Ollama models and exit")
    args = parser.parse_args()

    DEBUG       = args.debug
    MODEL       = args.model
    OLLAMA_HOST = args.host

    if args.list_models:
        list_models()
        return

    print(f"{BOLD}Local AI shell{RESET} — model: {CYAN}{MODEL}{RESET}  ollama: {CYAN}{OLLAMA_HOST}{RESET}")
    print(f"{GRAY}Commands: 'exit' to quit  |  '/audit' to start a structured security audit{RESET}\n")
    if DEBUG:
        print(f"{GRAY}[debug mode on]{RESET}\n")

    while True:
        try:
            prompt = input(f"{BOLD}>>{RESET} ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not prompt or prompt.lower() == "exit":
            break

        if prompt.lower() == "/audit":
            run_audit()
            print()
            continue

        print(f"{GRAY}Thinking...{RESET}", flush=True)
        ctx = freeform_context(prompt)
        dbg("context", ctx)
        try:
            reply = ask_ollama(prompt, system=FREEFORM_SYSTEM_PROMPT, context=ctx)
        except requests.RequestException:
            continue

        commands = extract_commands(reply)
        if not commands:
            print(f"{YELLOW}No commands found in response.{RESET}")
            continue

        print(f"\n{BOLD}Proposed commands:{RESET}")
        for i, cmd in enumerate(commands, 1):
            print(f"  {CYAN}{i}.{RESET} {cmd}")

        confirm = input(f"\n{BOLD}Run these?{RESET} [y/N] ").strip().lower()
        if confirm != "y":
            print("Skipped.")
            continue

        success, stderr_out = run_commands(commands)
        if not success and needs_sudo(stderr_out):
            retry = input(f"\n{YELLOW}Needs root. Retry with sudo?{RESET} [y/N] ").strip().lower()
            if retry == "y":
                run_commands(commands, sudo=True)
        print()


if __name__ == "__main__":
    main()
